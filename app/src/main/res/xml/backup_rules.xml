<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!-- Never back up the login session (the InnerTube cookie lives in the "settings" datastore): keeps
         it from being extracted via adb/cloud backup. Settings have their own in-app backup/restore. -->
    <exclude
        domain="file"
        path="datastore/settings.preferences_pb" />
    <exclude
        domain="file"
        path="./exoplayer" />
    <exclude
        domain="file"
        path="./download" />
    <exclude
        domain="database"
        path="exoplayer_internal.db" />
</full-backup-content>